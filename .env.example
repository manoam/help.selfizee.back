# Postgres (utilisé par docker-compose ET par Prisma)
POSTGRES_USER=help
POSTGRES_PASSWORD=help
POSTGRES_DB=help_selfizee
POSTGRES_PORT=5432

# Prisma — URL de la DB
# En local hors Docker : postgres://help:help@localhost:5432/help_selfizee
# Depuis le conteneur API (compose) : postgres://help:help@postgres:5432/help_selfizee
DATABASE_URL=postgres://help:help@localhost:5432/help_selfizee

# API Express
NODE_ENV=development
PORT=3001

# Keycloak — Selfizee plateformdev
KEYCLOAK_URL=https://plateformdev-auth.orkessi.com
KEYCLOAK_REALM=konitys
# Audience attendue dans le access_token (souvent = client-id)
KEYCLOAK_AUDIENCE=helpselfizee

# CORS — origines autorisées (front), CSV
CORS_ORIGINS=http://localhost:3000
