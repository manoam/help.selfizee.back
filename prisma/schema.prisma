// Schéma Prisma — help-selfizee back.
// Reflète les tables CakePHP du CRM Konitys en PostgreSQL moderne.
// pgvector activé via SQL manuel (cf. docker/postgres/init/02-add-embedding-column.sql).
//
// Auth : Keycloak (Selfizee plateformdev). Pas de table User locale —
// l'identité utilisateur est conservée via `authorKcSub` = `sub` du JWT Keycloak.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector, unaccent, pg_trgm]
}

// ----- Catégorisation à 3 niveaux (héritée du CRM) -----

model Category {
  id          Int      @id @default(autoincrement())
  nom         String   @db.VarChar(250)
  slug        String   @unique
  description String?
  afficher    Boolean  @default(true)
  ordre       Int      @default(0)
  legacyId    Int?     @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subCategories SubCategory[]
  posts         PostCategory[]
}

model SubCategory {
  id        Int      @id @default(autoincrement())
  nom       String   @db.VarChar(255)
  slug      String
  ordre     Int      @default(0)
  legacyId  Int?     @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categoryId       Int
  category         Category          @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  subSubCategories SubSubCategory[]
  posts            PostCategory[]

  @@unique([categoryId, slug])
}

model SubSubCategory {
  id        Int      @id @default(autoincrement())
  nom       String   @db.VarChar(255)
  slug      String
  ordre     Int      @default(0)
  legacyId  Int?     @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subCategoryId Int
  subCategory   SubCategory    @relation(fields: [subCategoryId], references: [id], onDelete: Cascade)
  posts         PostCategory[]

  @@unique([subCategoryId, slug])
}

// ----- Posts -----

model Post {
  id          Int        @id @default(autoincrement())
  titre       String
  slug        String     @unique
  resume      String?
  // `contenu` (JSON TipTap) correspond à l'ancien `contenu` (= notice interne) du CRM.
  // Les 9 textareas des vues client/callcenter/interne sont stockés en HTML brut (champs ci-dessous).
  contenu     Json
  contenuText String?
  status      PostStatus @default(DRAFT)
  isFavourite Boolean    @default(false)
  ordre       Int?
  legacyId    Int?       @unique
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  publishedAt DateTime?

  // Champs hérités du CRM, stockés en HTML brut. Édition future possible en TipTap.
  descriptionProbleme String?
  question            String?
  introClient         String?
  noticeClient        String?
  problemeClient      String?
  introCallCenter     String?
  noticeCallCenter    String?
  problemeCallCenter  String?
  introInterne        String?
  problemeInterne     String?

  // Identité de l'auteur — capturée depuis le token Keycloak au moment de la création.
  // Le `sub` Keycloak est stable et opaque ; `authorName` est dénormalisé pour l'affichage.
  authorKcSub String?
  authorName  String?

  categories     PostCategory[]
  tags           PostTag[]
  attachments    PostAttachment[]
  modelBornes    PostModelBorne[]
  typeProfils    PostTypeProfil[]
  votes          Vote[]
  relatedTo      PostRelation[]  @relation("PostRelationFrom")
  relatedFrom    PostRelation[]  @relation("PostRelationTo")

  @@index([status])
  @@index([publishedAt])
  @@index([authorKcSub])
  @@index([isFavourite])
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model PostCategory {
  id Int @id @default(autoincrement())

  postId           Int
  post             Post            @relation(fields: [postId], references: [id], onDelete: Cascade)
  categoryId       Int
  category         Category        @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  subCategoryId    Int?
  subCategory      SubCategory?    @relation(fields: [subCategoryId], references: [id], onDelete: SetNull)
  subSubCategoryId Int?
  subSubCategory   SubSubCategory? @relation(fields: [subSubCategoryId], references: [id], onDelete: SetNull)

  @@index([postId])
  @@index([categoryId])
}

// ----- Tags -----

model Tag {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(255)
  slug      String   @unique
  legacyId  Int?     @unique
  createdAt DateTime @default(now())

  posts PostTag[]
}

model PostTag {
  postId Int
  tagId  Int
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@index([tagId])
}

// ----- Posts liés -----

model PostRelation {
  fromId Int
  toId   Int
  from   Post @relation("PostRelationFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to     Post @relation("PostRelationTo", fields: [toId], references: [id], onDelete: Cascade)

  @@id([fromId, toId])
  @@index([toId])
}

// ----- Fichiers attachés -----

model PostAttachment {
  id           Int      @id @default(autoincrement())
  postId       Int
  filename     String
  originalName String?
  mimeType     String?
  sizeBytes    Int?
  storagePath  String
  label        String?
  description  String?
  legacyId     Int?     @unique
  createdAt    DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

// ----- Gammes et modèles de bornes (matériel physique Selfizee) -----

model GammeBorne {
  id        Int      @id @default(autoincrement())
  nom       String   @db.VarChar(255)
  slug      String   @unique
  legacyId  Int?     @unique
  createdAt DateTime @default(now())

  modelBornes ModelBorne[]
  posts       PostModelBorne[]
}

model ModelBorne {
  id        Int      @id @default(autoincrement())
  nom       String   @db.VarChar(255)
  version   String?  @db.VarChar(64)
  legacyId  Int?     @unique
  createdAt DateTime @default(now())

  gammeBorneId Int
  gammeBorne   GammeBorne       @relation(fields: [gammeBorneId], references: [id], onDelete: Cascade)
  posts        PostModelBorne[]

  @@index([gammeBorneId])
}

model PostModelBorne {
  id Int @id @default(autoincrement())

  postId       Int
  post         Post        @relation(fields: [postId], references: [id], onDelete: Cascade)
  gammeBorneId Int
  gammeBorne   GammeBorne  @relation(fields: [gammeBorneId], references: [id], onDelete: Restrict)
  modelBorneId Int?
  modelBorne   ModelBorne? @relation(fields: [modelBorneId], references: [id], onDelete: SetNull)

  @@index([postId])
  @@index([gammeBorneId])
}

// ----- Niveaux d'accès (profils utilisateurs) -----

model TypeProfil {
  id        Int      @id @default(autoincrement())
  nom       String   @db.VarChar(255)
  slug      String   @unique
  legacyId  Int?     @unique
  createdAt DateTime @default(now())

  posts PostTypeProfil[]
}

model PostTypeProfil {
  postId       Int
  typeProfilId Int
  post         Post       @relation(fields: [postId], references: [id], onDelete: Cascade)
  typeProfil   TypeProfil @relation(fields: [typeProfilId], references: [id], onDelete: Cascade)

  @@id([postId, typeProfilId])
  @@index([typeProfilId])
}

// ----- Votes utilisateurs (3 emojis : triste / neutre / heureux), repris du CRM. -----

enum VoteValue {
  SAD
  NEUTRAL
  HAPPY
}

model Vote {
  id          Int       @id @default(autoincrement())
  postId      Int
  voterKcSub  String    // sub du JWT Keycloak (ou "auth-disabled-bypass")
  value       VoteValue
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  // Un seul vote par (post, voter). Le re-vote update au lieu de créer.
  @@unique([postId, voterKcSub])
  @@index([postId])
  // Index composé pour groupBy(value) where postId.
  @@index([postId, value])
}

// ----- Historique des recherches (utilisé pour analytics + suggestions). -----

model AssistanceRecherche {
  id         Int      @id @default(autoincrement())
  text       String
  voterKcSub String?  // null si recherche anonyme
  createdAt  DateTime @default(now())

  @@index([createdAt])
}
